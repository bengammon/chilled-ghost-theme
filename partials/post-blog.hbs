<article class="post-teaser {{post_class}} post-year-{{date format='Y'}}">

    <div class="post-teaser__year">
        <span class="post-teaser__year-text">{{date format='YYYY'}}</span>
    </div>

    <p class="post-teaser__heading"><a class="post-teaser__title" href="{{url}}">{{title}}</a></p>

    <div class="post-teaser__date">
        {{date format="MM/DD"}}
    </div>

    {{#primary_tag}}
        <a class="tag" "{{url}}">{{name}}</a>
    {{/primary_tag}}

</article>
