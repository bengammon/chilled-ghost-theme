<article class="post-teaser {{post_class}} post-year-{{date format="Y"}}">
    
    <time class="post-teaser__meta" datetime="{{date format='MMMM DD, YYYY'}}">
        {{date format="MMMM DD, YYYY"}} 
        {{#primary_tag}}
		    &#8226; <a href="{{url}}" title="{{name}}">{{name}}</a>
        {{/primary_tag}}
    </time>

    <h3 class="post-teaser__heading"><a class="post-teaser__title" href="{{url}}">{{title}}</a> <span class="post-teaser__excerpt">{{excerpt characters="140"}}</span></h3>

</article>
