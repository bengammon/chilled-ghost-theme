<article class="post-teaser {{post_class}} post-year-{{date format="Y"}}">

    <div class="post-teaser__content">

        <h2 class="post-teaser__heading"><a class="post-teaser__title" href="{{url}}">{{title}}</a></h2>

        <p class="post-teaser__excerpt">{{excerpt}}</p>

    </div>

    <div class="post-teaser__date">{{date format="MMM YYYY"}}</div>

</article>
