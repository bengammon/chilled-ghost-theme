<div class="columns">
	{{#get "posts" include="tags" limit="2" filter="id:-{{id}}+tag:{{primary_tag.slug}}" as |related|}}
		{{#foreach related}}
			<div class="column card">
				
				<article class="post-teaser {{post_class}} read-next">

					<a class="post-teaser__date" href="{{url}}">{{date format="dddd, D MMMM YYYY"}}</a>

					<h3 class="post-teaser__heading"><a class="post-teaser__title" href="{{url}}">{{title}}</a></h3>

				</article>

			</div>
		{{/foreach}}
		{{else}}
			<p>There are no related posts available.</p>
	{{/get}}
</div>