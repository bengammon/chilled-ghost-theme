{{!< default}}

<div class="layout__content gh-content">

{{#get "posts" include="tags" filter="tags:-microblog" limit="all"}}

    <h1>Blog</h1>

    <div class="spacer--medium"></div>

    <div class="archive">
        {{#get "posts" include="tags" limit="all"}}
            {{#foreach posts}}
                {{> post-teaser}}
            {{/foreach}}
        {{/get}}
    </div>

{{/get}}

</div>

<div class="layout__sidebar-right">

    <aside class="sidebar gh-sidebar">
        
        <h2 class="subheading">Tags</h2>

        {{> tags}}

    </aside>

</div>