{{!< default}}

{{#post}}

<article class="{{post_class}} gh-content" data-post-date="{{published_at}}" data-post-id="{{id}}">

    <h1 class="post__title">{{title}} <span class="post__number js-post-number" style="opacity: 0;"></span></h1>

    <div class="post__meta">
        {{^has tag="note"}}
            <time class="post__date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD/MM/YY"}}</time>
        {{/has}}
        {{#if tags}}
            <ul class="post__tags list">
                {{#foreach tags}}
                <li>
                    <a class="post__tag" href="{{url}}" title="{{name}}">#{{name}}</a>
                </li>
                {{/foreach}}
            </ul>
        {{/if}}
    </div>

    {{content}}

    {{^has tag="note"}}
    <div class="post__subscribe">
        {{^if @member}}
        <hr>
        <div class="subscribe-cta">
            <p>Enjoyed this? I write about CSS, web development, gaming, and whatever else catches my eye. Subscribe to get new posts by email — no spam, unsubscribe any time.</p>
            <form data-members-form="subscribe" class="subscribe-cta__form">
                <input class="subscribe-cta__input" data-members-email type="email" placeholder="your@email.com" required />
                <button class="btn subscribe-cta__btn" type="submit">Subscribe</button>
                <div class="subscribe-cta__success" style="display:none">✓ You're subscribed!</div>
                <div class="subscribe-cta__error" style="display:none">Something went wrong. Please try again.</div>
            </form>
        </div>
        {{/if}}
    </div>
    {{/has}}
</article>

{{/post}}